# Copy to .env on the server (e.g. /opt/crm/.env).
# docker-compose.prod.yml reads this file.

# Required for compose (PostgreSQL)
POSTGRES_PASSWORD=your_strong_password

# Backend: copy the rest from apps/backend/.env.example and fill:
# DATABASE_URL is overridden by compose (postgresql://crm:POSTGRES_PASSWORD@postgres:5432/crm)
# JWT_SECRET=...
# CORS_ORIGIN=https://your-domain.com,https://store.your-domain.com
# NP_*, TELEGRAM_*, etc.
