DATABASE_URL="xxxxx"
JWT_SECRET="xxxx"

# Set CRON_ENABLED=true on the server so scheduled jobs (Bank sync, NP TTN, Ringostat, Bitrix) run. Leave unset locally to avoid P1017 connection errors with Docker Postgres.
# CRON_ENABLED=true

# Store (internet shop): ownerId for orders from store. Run seed and copy id from log "STORE_OWNER_ID for .env"
# STORE_OWNER_ID=

# CORS (production): comma-separated list of allowed origins, e.g. https://app.example.com,https://admin.example.com
# CORS_ORIGIN=https://your-frontend-domain.com

NP_API_URL=https://api.novaposhta.ua/v2.0/json/
NP_API_KEY=xxxxx
# Таймаут запроса к НП (мс). При повільному інтернеті або Connect Timeout збільште, напр. 60000
# NP_API_TIMEOUT_MS=30000

# Sender (Dnipro, WH 75)
NP_SENDER_CITY_REF=xxxxxx
#NP_SENDER_COUNTERPARTY_REF="10000000000000000000000000000000"
#NP_SENDER_CONTACT_REF="10000000000000000000000000000000"
NP_SENDER_WAREHOUSE_REF=xxxxxx

# данные отправителя (для Counterparty/ContactPerson)
NP_SENDER_FIRST_NAME=xxxx
NP_SENDER_LAST_NAME=xxxx
NP_SENDER_PHONE=xxxx

# defaults
NP_DEFAULT_PAYER_TYPE=Recipient
NP_DEFAULT_PAYMENT_METHOD=Cash

# Privat24 Business API (bank sync). Optional; default https://api.privatbank.ua
# PRIVAT24_API_URL=https://api.privatbank.ua

# Telegram bot (Inbox integration)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
PUBLIC_BASE_URL=
# Store: bot username for "link Telegram" deep link (e.g. MyShopBot)
# STORE_TELEGRAM_BOT_USERNAME=
# Optional: company for new leads from Telegram (default: first company)
# TELEGRAM_LEAD_COMPANY_ID=

# Telegram Inbox AI (suggest replies). Optional; can set in Settings → Telegram instead.
# OPENAI_API_KEY=

# Bitrix migration & sync (initial import from MySQL, delta via REST)
# If MySQL is reached via SSH tunnel, use BITRIX_MYSQL_HOST=127.0.0.1 and PORT=3307 (tunnel -L 3307:127.0.0.1:3306).
# BITRIX_MYSQL_HOST=localhost
# BITRIX_MYSQL_PORT=3306
# BITRIX_MYSQL_USER=
# BITRIX_MYSQL_PASSWORD=
# BITRIX_MYSQL_DATABASE=bitrix
# Connection timeout in ms (default 60000). Increase if using slow SSH tunnel.
# BITRIX_MYSQL_CONNECT_TIMEOUT_MS=60000
# BITRIX_WEBHOOK_URL=https://your-portal.bitrix24.com/rest/1/webhook_code/
# BITRIX_SYNC_ENABLED=false
# Bulk initial import: batch size (default 1000), max concurrent batches per entity (default 4)
# BITRIX_IMPORT_BATCH_SIZE=1000
# BITRIX_IMPORT_CONCURRENCY=4
# BITRIX_IMPORT_ORDER_TX_TIMEOUT_MS=60000
# Import only users with UF_DEPARTMENT set (employees). Set to false to import all b_user rows.
# BITRIX_IMPORT_EMPLOYEES_ONLY=true

# Bitrix live webhook sync (optional; works alongside cron delta sync)
# BITRIX_WEBHOOK_ENABLED=true
# BITRIX_WEBHOOK_SECRET=your_secret_token
# Bitrix sends this in header: x-bitrix-webhook-secret

# Product images sync from Google Drive (optional)
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# Path to service account JSON key file, or use GOOGLE_SERVICE_ACCOUNT_JSON with JSON string
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
