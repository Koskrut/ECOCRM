# ============================================================
# Production .env for docker-compose (root of repo on server)
# Copy to .env and replace placeholders:
#   cp .env.production.example .env
#   nano .env
# ============================================================

# Required by docker-compose.prod.yml (PostgreSQL container)
POSTGRES_PASSWORD=ЗАМІНИТИ_НА_НАДІЙНИЙ_ПАРОЛЬ

# Backend (DATABASE_URL задається в compose автоматично)
JWT_SECRET=ЗАМІНИТИ_НА_ДОВГУ_ВИПАДКОВУ_СТРОКУ

# CORS: дозволені джерела (HTTPS-домени через кому)
CORS_ORIGIN=https://crm.suprex.dental,https://www.suprex.dental

# Публічний URL бекенда для webhook (Telegram, Ringostat, Bitrix)
PUBLIC_BASE_URL=https://api.suprex.dental

# Store: ownerId для замовлень з магазину (опційно; після seed взяти з лога STORE_OWNER_ID)
# STORE_OWNER_ID=

# --- Nova Poshta ---
NP_API_URL=https://api.novaposhta.ua/v2.0/json/
NP_API_KEY=ЗАМІНИТИ_НА_ВАШ_КЛЮЧ_НП
# NP_API_TIMEOUT_MS=30000

NP_SENDER_CITY_REF=ЗАМІНИТИ_REF_МІСТА
NP_SENDER_WAREHOUSE_REF=ЗАМІНИТИ_REF_ВІДДІЛЕННЯ
NP_SENDER_FIRST_NAME=Імʼя
NP_SENDER_LAST_NAME=Прізвище
NP_SENDER_PHONE=380XXXXXXXXX

NP_DEFAULT_PAYER_TYPE=Recipient
NP_DEFAULT_PAYMENT_METHOD=Cash

# --- Telegram (Inbox) — опційно ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
# PUBLIC_BASE_URL задано вище (https://api.suprex.dental)
# STORE_TELEGRAM_BOT_USERNAME=
# TELEGRAM_LEAD_COMPANY_ID=
# OPENAI_API_KEY=

# --- Bitrix import (якщо запускаєте npm run bitrix:import на цьому хості) ---
# POSTGRES_PASSWORD вже є вище — скрипт збере DATABASE_URL для 127.0.0.1:5432.
# Якщо Bitrix MySQL через SSH-туннель: BITRIX_MYSQL_HOST=127.0.0.1, BITRIX_MYSQL_PORT=3307 та ін.
# BITRIX_MYSQL_HOST=127.0.0.1
# BITRIX_MYSQL_PORT=3307
# BITRIX_MYSQL_USER=
# BITRIX_MYSQL_PASSWORD=
# BITRIX_MYSQL_DATABASE=bitrix
# BITRIX_WEBHOOK_URL=https://...

# --- Privat24 / інше — за потреби з apps/backend/.env.example ---
